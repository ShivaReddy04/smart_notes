# .env.example
#
# Why this file exists:
#   Committed template that documents EVERY environment variable the
#   application reads (see app/core/config.py). It contains no real
#   secrets and is safe to keep in version control. To run the app, copy
#   this file to `.env` and fill in real values:
#
#       cp .env.example .env
#
#   The real `.env` is git-ignored so credentials never enter the repo.
#   Variable names are matched case-insensitively, so DATABASE_URL maps to
#   the `database_url` setting.

# --- Database (REQUIRED) ---------------------------------------------
# SQLAlchemy connection URL. There is intentionally no default: the app
# refuses to start without an explicit database target.
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<database>
#   * +psycopg2 selects the driver we depend on (psycopg2-binary).
#   * 5432 is PostgreSQL's default port.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_smart_notes

# --- AI / OpenRouter (Phase 2) ---------------------------------------
# REQUIRED for AI features. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Model slug in "vendor/model" form (OPTIONAL: default shown).
OPENROUTER_MODEL=openai/gpt-4o-mini
# OpenAI-compatible endpoint (OPTIONAL: default shown).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Generation tuning (OPTIONAL: defaults shown).
LLM_TEMPERATURE=0.0
LLM_TIMEOUT=30.0

# --- Embeddings & vector search (Phase 3) (OPTIONAL: defaults shown) --
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PERSIST_PATH=./chroma_data
CHROMA_COLLECTION_NAME=notes
SEARCH_TOP_K=5
EMBEDDING_DEVICE=cpu

# --- Frontend / CORS (Phase 5) (OPTIONAL: default = local Vite dev server) ---
# Origins allowed to call this API from a browser. Complex (list) value, so it
# must be a JSON array when set here. Defaults (in config.py) cover local dev.
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Application metadata (OPTIONAL: defaults shown) ------------------
# These have sensible defaults in config.py; override only if needed.
APP_NAME=AI Smart Notes
APP_VERSION=0.1.0

# Set to true to enable FastAPI/Starlette debug behavior in development.
# Keep false in production.
DEBUG=false

# Prefix every API route is mounted under (lets us version the API).
API_V1_PREFIX=/api/v1
