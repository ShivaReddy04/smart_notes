# .env.example
#
# Why this file exists:
#   Committed template that documents EVERY environment variable the
#   application reads (see app/core/config.py). It contains no real
#   secrets and is safe to keep in version control. To run the app, copy
#   this file to `.env` and fill in real values:
#
#       cp .env.example .env
#
#   The real `.env` is git-ignored so credentials never enter the repo.
#   Variable names are matched case-insensitively, so DATABASE_URL maps to
#   the `database_url` setting.

# --- Database (REQUIRED) ---------------------------------------------
# SQLAlchemy connection URL. There is intentionally no default: the app
# refuses to start without an explicit database target.
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<database>
#   * +psycopg2 selects the driver we depend on (psycopg2-binary).
#   * 5432 is PostgreSQL's default port.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_smart_notes

# --- AI / OpenRouter (Phase 2) ---------------------------------------
# REQUIRED for AI features. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Model slug in "vendor/model" form (OPTIONAL: default shown).
OPENROUTER_MODEL=openai/gpt-4o-mini
# OpenAI-compatible endpoint (OPTIONAL: default shown).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Generation tuning (OPTIONAL: defaults shown).
LLM_TEMPERATURE=0.0
LLM_TIMEOUT=30.0

# --- Embeddings & vector search (Phase 3) ----------------------------
# Embeddings come from a HOSTED, OpenAI-compatible API (no local torch). The
# vectors are stored in Postgres via pgvector, so DATABASE_URL above must point
# at a database where the `vector` extension is available (Neon has it; the
# migration runs `CREATE EXTENSION IF NOT EXISTS vector`).
#
# REQUIRED: embeddings API key. For the default Gemini endpoint, get a free key
# at https://aistudio.google.com/apikey
EMBEDDING_API_KEY=your-gemini-api-key-here
# OpenAI-compatible embeddings endpoint (OPTIONAL: default = Gemini, shown).
EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Embedding model slug (OPTIONAL: default shown).
EMBEDDING_MODEL=gemini-embedding-001
# Vector width to request — MUST match the pgvector column (migration 0004).
# gemini-embedding-001 supports 768/1536/3072 (OPTIONAL: default shown).
EMBEDDING_DIMENSIONS=768
# Per-call timeout in seconds (OPTIONAL: default shown).
EMBEDDING_TIMEOUT=30.0
# Default number of semantic-search results (OPTIONAL: default shown).
SEARCH_TOP_K=5

# --- Image storage (Phase 5) -----------------------------------------
# Where uploaded note-image BYTES go. "local" stores them on disk (dev); "s3"
# stores them in any S3-compatible object storage (production / free tier, which
# has no persistent disk) — Supabase Storage by default, also R2 / AWS / MinIO.
# (OPTIONAL: default = local, shown.)
IMAGE_STORAGE_BACKEND=local
# Local backend only: directory for stored image bytes (OPTIONAL: default shown).
MEDIA_DIR=./media
# S3 backend only (REQUIRED when IMAGE_STORAGE_BACKEND=s3). All blank by default.
# For Supabase: create a PUBLIC bucket, then Storage -> S3 Access Keys.
#   S3_ENDPOINT_URL    -> https://<project_ref>.supabase.co/storage/v1/s3
#   S3_REGION          -> your Supabase project region (Storage settings), e.g. us-east-1
#   S3_PUBLIC_BASE_URL -> https://<project_ref>.supabase.co/storage/v1/object/public/<bucket>
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=

# --- Frontend / CORS (Phase 5) (OPTIONAL: default = local Vite dev server) ---
# Origins allowed to call this API from a browser. Complex (list) value, so it
# must be a JSON array when set here. Defaults (in config.py) cover local dev.
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Application metadata (OPTIONAL: defaults shown) ------------------
# These have sensible defaults in config.py; override only if needed.
APP_NAME=AI Smart Notes
APP_VERSION=0.1.0

# Set to true to enable FastAPI/Starlette debug behavior in development.
# Keep false in production.
DEBUG=false

# Prefix every API route is mounted under (lets us version the API).
API_V1_PREFIX=/api/v1
